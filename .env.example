# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and not pushed to GitHub.

# ReCAPTCHA (get keys at https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# SendGrid (get key at https://app.sendgrid.com/)
SendGridDevKey=
# Optional: also accepted as SENDGRID_API_KEY
SENDGRID_API_KEY=

# Optional: SendGrid dynamic template for “verify your email” (otherwise a simple HTML mail is sent)
SENDGRID_EMAIL_VERIFICATION_TEMPLATE_ID=

# Mentor application: dynamic template to applicant (SendGrid) — sent after email is verified
SENDGRID_MENTOR_APPLY_TEMPLATE_ID=
# After admin approves a pending mentor — “application accepted” email (SendGrid)
SENDGRID_MENTOR_ACCEPTED_TEMPLATE_ID=
# After mentor saves profile for review (PENDING_REVIEW) — “we received your profile” (SendGrid)
SENDGRID_MENTOR_PROFILE_SUBMITTED_TEMPLATE_ID=
# After admin publishes mentor (profile live on website) — “you’re live” (SendGrid)
SENDGRID_MENTOR_PROFILE_LIVE_TEMPLATE_ID=
# Assessment: invitation email when admin dispatches a test (dynamic template)
SENDGRID_ASSESSMENT_DISPATCH_TEMPLATE_ID=
# Assessment: confirmation after student finishes / auto-submit (graded) — see docs/sendgrid-assessment-completion-template.md
SENDGRID_ASSESSMENT_COMPLETION_TEMPLATE_ID=
# Site origin for links in emails (no trailing slash). Also APP_BASE_URL on the server.
NEXT_PUBLIC_APP_URL=
# From address (must be verified in SendGrid)
MAIL_FROM=

# Team inbox for internal notifications (mentor apply, profile review, and every mock/mentorship order)
# Defaults to contact@madalgos.in if unset
MENTOR_APPLY_NOTIFY_EMAIL=
CONTACT_TEAM_EMAIL=

# Cosmos DB / MongoDB (optional — for saving Contact inquiries)
DATABASE_URI=
# Optional DB name when URI has no path segment
DATABASE_NAME=
# Legacy aliases still supported by runtime:
# MONGODB_URI=
# MONGODB_DB_NAME=
# Optional: initial connect wall-clock timeout in ms (default 25000; raise if Atlas is slow)
# MONGODB_CONNECT_TIMEOUT_MS=

# Optional — img.logo.dev token for company logos (Alumni + practice test cards). Falls back to built-in dev key.
# NEXT_PUBLIC_LOGO_DEV_TOKEN=

# Brochure download URL (hero "Download Brochure" button).
# Use NEXT_PUBLIC_BROCHURE_URL for build-time, or BROCHURE_URL in Azure App Service for runtime (no rebuild).
NEXT_PUBLIC_BROCHURE_URL=
# BROCHURE_URL=   # optional: server-only, used by /api/public-config so brochure works at runtime

# Razorpay (https://dashboard.razorpay.com/) — use rzp_test_* for test mode, rzp_live_* for production
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: same as RAZORPAY_KEY_ID — avoids GET /api/payments/razorpay-key on pay click
# NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Judge0 code execution (assessment coding problems). URL host must match your RapidAPI subscription.
# Example — Judge0 Extra CE: https://rapidapi.com/judge0-official/api/judge0-extra-ce
# JUDGE0_API_URL=https://judge0-extra-ce1.p.rapidapi.com
# JUDGE0_API_KEY=
