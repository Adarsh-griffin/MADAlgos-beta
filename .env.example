# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and not pushed to GitHub.

# ReCAPTCHA (get keys at https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# SendGrid (get key at https://app.sendgrid.com/)
SendGridDevKey=
# Optional: also accepted as SENDGRID_API_KEY
SENDGRID_API_KEY=

# Optional: SendGrid dynamic template for “verify your email” (otherwise a simple HTML mail is sent)
SENDGRID_EMAIL_VERIFICATION_TEMPLATE_ID=

# Mentor application: dynamic template to applicant (SendGrid) — sent after email is verified
SENDGRID_MENTOR_APPLY_TEMPLATE_ID=
# After admin approves a pending mentor — “application accepted” email (SendGrid)
SENDGRID_MENTOR_ACCEPTED_TEMPLATE_ID=
# After mentor saves profile for review (PENDING_REVIEW) — “we received your profile” (SendGrid)
SENDGRID_MENTOR_PROFILE_SUBMITTED_TEMPLATE_ID=
# After admin publishes mentor (profile live on website) — “you’re live” (SendGrid)
SENDGRID_MENTOR_PROFILE_LIVE_TEMPLATE_ID=
# From address (must be verified in SendGrid)
MAIL_FROM=

# Team inbox for internal notifications (mentor apply + mentor profile review; defaults to contact@madalgos.in)
MENTOR_APPLY_NOTIFY_EMAIL=
CONTACT_TEAM_EMAIL=

# Cosmos DB / MongoDB (optional — for saving Contact inquiries)
MONGODB_URI=

# Brochure download URL (hero "Download Brochure" button).
# Use NEXT_PUBLIC_BROCHURE_URL for build-time, or BROCHURE_URL in Azure App Service for runtime (no rebuild).
NEXT_PUBLIC_BROCHURE_URL=
# BROCHURE_URL=   # optional: server-only, used by /api/public-config so brochure works at runtime
